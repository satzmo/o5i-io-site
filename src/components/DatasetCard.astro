---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  dataset: CollectionEntry<'datasets'>;
}

const { dataset } = Astro.props;
const d = dataset.data;
const isLive = d.status === 'live' && !!d.hf_url;
// Not-yet-live CTA label: derive "Coming <Month Year>" from the first confirmed
// roadmap entry so it tracks the schedule instead of drifting (cf. the stale
// "July 2026" left over from the pre-S1a/S1b split).
const upcoming = d.series_roadmap?.find((s) => s.status === 'confirmed');
const comingLabel = upcoming?.target_date
  ? new Date(upcoming.target_date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : null;
const { Content } = await render(dataset);
---
<article class="border border-neutral-200 rounded-lg p-8 max-w-2xl mx-auto bg-white">
  <h3 class="text-2xl font-semibold text-neutral-900">{d.name}</h3>
  <p class="mt-2 text-neutral-700">{d.tagline}</p>

  <dl class="mt-6 space-y-3 text-sm">
    <div class="grid grid-cols-1 gap-1 sm:grid-cols-[100px_1fr] sm:gap-3">
      <dt class="font-mono text-neutral-700 uppercase text-xs pt-0.5">Purpose</dt>
      <dd class="text-neutral-800">{d.purpose}</dd>
    </div>
    <div class="grid grid-cols-1 gap-1 sm:grid-cols-[100px_1fr] sm:gap-3">
      <dt class="font-mono text-neutral-700 uppercase text-xs pt-0.5">Frontier</dt>
      <dd class="text-neutral-800">{d.frontier}</dd>
    </div>
    <div class="grid grid-cols-1 gap-1 sm:grid-cols-[100px_1fr] sm:gap-3">
      <dt class="font-mono text-neutral-700 uppercase text-xs pt-0.5">License</dt>
      <dd class="text-neutral-800">
        Trial — {d.accessibility.trial}<br/>
        Standard — {d.accessibility.standard}<br/>
        Enterprise — {d.accessibility.enterprise}
      </dd>
    </div>
    <div class="grid grid-cols-1 gap-1 sm:grid-cols-[100px_1fr] sm:gap-3">
      <dt class="font-mono text-neutral-700 uppercase text-xs pt-0.5">Cite</dt>
      <dd class="text-neutral-800 italic">{d.citation}</dd>
    </div>
    {d.series_roadmap && d.series_roadmap.length > 0 && (
      <div class="grid grid-cols-1 gap-1 sm:grid-cols-[100px_1fr] sm:gap-3">
        <dt class="font-mono text-neutral-700 uppercase text-xs pt-0.5">Roadmap</dt>
        <dd class="text-neutral-800">
          <ul class="space-y-1">
            {d.series_roadmap.map((s) => (
              <li class="sm:grid sm:grid-cols-[1fr_auto] sm:gap-x-3 sm:items-baseline">
                <span>
                  <span class="font-mono text-xs text-neutral-700">{s.code}</span>
                  <span class="font-medium ml-2">{s.name}</span>
                  <span class="text-neutral-700"> — {s.layer}</span>
                </span>
                <span class={s.status === 'confirmed'
                  ? 'block sm:text-right font-mono text-xs text-neutral-900 whitespace-nowrap'
                  : 'block sm:text-right font-mono text-xs text-neutral-600 whitespace-nowrap'}>
                  {s.target_date} · {s.status}
                </span>
              </li>
            ))}
          </ul>
          <p class="mt-2 text-xs text-neutral-600 italic">
            S1 confirms the schema in two steps (Trial release, then Commercial activation). Subsequent series ship only if S1 finds users — we publish on demand validation, not on a fixed roadmap.
          </p>
        </dd>
      </div>
    )}
  </dl>

  <div class="mt-8">
    {isLive ? (
      <a
        href={d.hf_url}
        class="inline-block px-5 py-2 rounded bg-neutral-900 text-white font-medium hover:bg-neutral-700"
        rel="noopener"
      >
        View on Hugging Face →
      </a>
    ) : (
      <span class="inline-block px-5 py-2 rounded bg-neutral-200 text-neutral-700 font-medium cursor-not-allowed">
        View on Hugging Face →{comingLabel ? ` (Coming ${comingLabel})` : ''}
      </span>
    )}
  </div>

  <div class="mt-10 pt-8 border-t border-neutral-200 prose prose-sm prose-neutral max-w-none prose-headings:font-mono prose-headings:uppercase prose-headings:tracking-wide prose-h2:text-sm prose-h2:text-neutral-700 prose-p:text-neutral-800 prose-p:leading-relaxed">
    <Content />
  </div>
</article>

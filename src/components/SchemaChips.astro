---
const slots = [
  'purpose',
  'ethical_use',
  'frontier',
  'accessibility',
  'citation',
  'agi_relevance',
  'automation_load',
];
---
<div class="flex flex-wrap gap-2 justify-center mt-6">
  {slots.map((slot) => (
    <span class="px-3 py-1 text-xs font-mono rounded-full bg-neutral-100 text-neutral-700 border border-neutral-200">
      {slot}
    </span>
  ))}
</div>
